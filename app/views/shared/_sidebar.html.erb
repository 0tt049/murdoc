<div class="sidebar">
  <ul>
    <div class="logo">

    <li id="mur">
      <h1>MUR</h1>
    </li>

    <li id="doc">
      <h1>DOC</h1>
    </li>

    </div>
    <div class="side-items">

      <li class="side-item">
        <%= link_to root_path,
        data: { turbo_frame: 'load',
                action: 'click->replace-partial#replacePartial'
              } do %>
          <i class="fa-solid fa-table-cells-large"></i>
          <span>Browse Ruby</span>
        <% end %>
      </li>

      <li class="side-item">
        <%= link_to tree_path,
        data: { turbo_frame: 'load',
                action: 'click->replace-partial#replacePartial'
              } do %>
          <i class="fa-solid fa-tree"></i>
          <span>Tree</span>
        <% end %>
      </li>

      <li class="side-item">
        <%= link_to download_path,
        data: { turbo_frame: 'load',
                action: 'click->replace-partial#replacePartial'
              } do %>
          <i class="fa-solid fa-circle-down"></i>
          <span><p>Download Ruby</p></span>
        <% end %>

      </li>

      <li class="side-item">
        <%= link_to about_path,
        data: { turbo_frame: 'load',
                action: 'click->replace-partial#replacePartial'
              } do %>
          <i class="fa-brands fa-readme"></i>
          <span>About</span>
        <% end %>

      </li>


    </div>
  </ul>
</div>
